{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "AI Course details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructor": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "thumbnail": { "type": "string" },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "lessons": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": { "type": "string" },
                    "videoUrl": { "type": "string" },
                    "duration": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["title", "price", "instructor"]
    },
    "Order": {
      "title": "Order",
      "description": "Payment and order records",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["created", "paid", "failed"] },
        "razorpayOrderId": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "amount", "status"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User course progress tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "lastWatchedLesson": { "type": "string" },
        "progressPercentage": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Payment transactions"
    },
    "/progress/{progressId}": {
      "schema": "Progress",
      "description": "User course progress"
    }
  }
}
