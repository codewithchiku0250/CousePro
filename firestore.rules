rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields: uid, email, displayName, photoURL, role, createdAt
    //
    // Collection: courses
    // Document ID: courseId
    // Fields: title, description, instructor, price, duration, thumbnail, modules
    //
    // Collection: orders
    // Document ID: orderId
    // Fields: orderId, userId, courseId, amount, currency, status, razorpayOrderId, razorpayPaymentId, createdAt
    //
    // Collection: progress
    // Document ID: progressId (userId_courseId)
    // Fields: userId, courseId, completedLessons, lastWatchedLesson, progressPercentage, updatedAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "al9434365@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'price', 'instructor']) &&
             data.title is string && data.title.size() < 200 &&
             data.price is number && data.price >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'courseId', 'amount', 'status']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.status in ['created', 'paid', 'failed'];
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['userId', 'courseId']) &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /courses/{courseId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin(); // Only admin (or backend via admin SDK) should update orders
    }

    match /progress/{progressId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAuthenticated() && isValidProgress(request.resource.data) && request.auth.uid == request.resource.data.userId;
    }
  }
}
